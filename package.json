    "@wxt-dev/module-svelte": "^2.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^16.0.0",
    "svelte": "^5.27.1",
    "svelte-check": "^4.0.7",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "wxt": "^0.20.0"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "ua-parser-js": "^2.0.3",
    "v8n": "^1.5.1"
