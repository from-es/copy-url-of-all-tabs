{
  "name": "copy-url-of-all-tabs",
  "description": "Chrome extension",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/from-es/copy-url-of-all-tabs.git"
  },
  "bugs": {
    "url": "https://github.com/from-es/copy-url-of-all-tabs/issues"
  },
  "homepage": "https://github.com/from-es/copy-url-of-all-tabs",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:sourcemap": "wxt build --mode sourcemap",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "eslint": "eslint src"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "@types/chrome": "^0.0.315",
