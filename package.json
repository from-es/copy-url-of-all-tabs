{
  "name": "copy-url-of-all-tabs",
  "description": "Copy all open tab URLs in various formats or Open all URLs in the clipboard at once. Cross-browser extension supporting both Chrome and Firefox.",
  "version": "1.20.3",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/from-es/copy-url-of-all-tabs.git"
  },
  "bugs": {
    "url": "https://github.com/from-es/copy-url-of-all-tabs/issues"
  },
  "homepage": "https://github.com/from-es/copy-url-of-all-tabs",
  "scripts": {
    "dev:chrome"        : "wxt --browser chrome --mv3",
    "dev:firefox"       : "wxt --browser firefox --mv3",
    "build:chrome:prod" : "wxt build --browser chrome --mv3",
    "build:chrome:dev"  : "wxt build --browser chrome --mv3 --mode sourcemap",
    "build:firefox:prod": "wxt build --browser firefox --mv3",
    "build:firefox:dev" : "wxt build --browser firefox --mv3 --mode sourcemap",
    "zip:chrome"        : "wxt zip --browser chrome --mv3",
    "zip:firefox"       : "wxt zip --browser firefox --mv3",

    "check" : "svelte-check --tsconfig ./tsconfig.json",
    "eslint": "eslint src",

    "vitest"         : "vitest",
    "vitest:run"     : "vitest run",
    "vitest:ui"      : "vitest --ui",
    "vitest:coverage": "vitest run --coverage",
    "vitest:smoke"   : "vitest run ./tests/_vitest-check/",

    "postinstall": "wxt prepare",
    "prepare"    : "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.9",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "@wxt-dev/module-svelte": "^2.0.5",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "bowser": "^2.14.1",
    "color-string": "^2.1.4",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "lodash-es": "^4.17.23",
    "marked": "^17.0.5",
    "modern-normalize": "^3.0.1",
    "p-queue": "^9.1.0",
    "sortablejs": "^1.15.7",
    "v8n": "^1.5.1"
  }
}
